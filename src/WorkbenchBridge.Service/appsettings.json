{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "WorkbenchBridge": "Debug",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "Bridge": {
    "Pi": {
      "Host": "192.168.8.32",
      "PortalPort": 8080,
      "DiscoveryEndpoint": "/api/devices"
    },
    "ComPortRange": {
      "UserPortStart": 41,
      "InternalPortOffset": 200
    },
    "ComPortMapping": [
      {
        "SlotLabel": "SLOT1",
        "UserPort": "COM41",
        "InternalPort": "COM241",
        "PiTcpPort": 4001
      },
      {
        "SlotLabel": "SLOT2",
        "UserPort": "COM42",
        "InternalPort": "COM242",
        "PiTcpPort": 4002
      },
      {
        "SlotLabel": "SLOT3",
        "UserPort": "COM43",
        "InternalPort": "COM243",
        "PiTcpPort": 4003
      }
    ],
    "Tools": {
      "Com0comPath": "C:\\Program Files (x86)\\com0com",
      "EsptoolPath": "C:\\Program Files\\esptool-windows-amd64"
    },
    "Service": {
      "DiscoveryPollingIntervalSeconds": 10,
      "ReconnectDelayMs": 5000
    }
  }
}
