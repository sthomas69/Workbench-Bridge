{
  "pi": {
    "host": "192.168.8.32",
    "portalPort": 8080,
    "discoveryEndpoint": "/api/devices"
  },
  "comPortRange": {
    "userPortStart": 41,
    "internalPortOffset": 200,
    "note": "COM41 pairs with COM241, COM42 pairs with COM242, etc."
  },
  "comPortMapping": [
    {
      "slotLabel": "SLOT1",
      "userPort": "COM41",
      "internalPort": "COM241",
      "piTcpPort": 4001
    },
    {
      "slotLabel": "SLOT2",
      "userPort": "COM42",
      "internalPort": "COM242",
      "piTcpPort": 4002
    },
    {
      "slotLabel": "SLOT3",
      "userPort": "COM43",
      "internalPort": "COM243",
      "piTcpPort": 4003
    }
  ],
  "tools": {
    "com0comPath": "C:\\Program Files (x86)\\com0com",
    "esptoolPath": "C:\\Program Files\\esptool-windows-amd64"
  },
  "service": {
    "discoveryPollingIntervalSeconds": 10,
    "reconnectDelayMs": 5000
  }
}
